```{r get-cols-function}
get_cols <- function(category) {
  df_dict |>
    filter(data_category == category) |>
    select(`variable name - description`) |>
    mutate(col_names = gsub(" -.*", "", `variable name - description`)) |>
    pull(col_names)
}

diet_cols  <- get_cols("Diet")
blood_cols <- get_cols("Blood markers")
sleep_cols <- get_cols("Sleep quality (self-report)")
pa_cols    <- get_cols("Physical Activity (self-report)")
cog_cols   <- get_cols("Cognitive")
demo_cols  <- get_cols("Participant info/Demographics")
```


```{r build-dataframes, warning=FALSE}
id_cols <- c("id_event", "id", "event", "study")

blood_data <- df |>
  select(all_of(id_cols), any_of(blood_cols)) |>
  mutate(across(-all_of(id_cols), as.numeric))

diet_data <- df |>
  select(all_of(id_cols), any_of(diet_cols)) |>
  mutate(across(-all_of(id_cols), as.numeric))

sleep_data <- df |>
  select(all_of(id_cols), any_of(sleep_cols)) |>
